{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalSheets",
  "version": "0.2.2",
  "identifier": "com.taylor.localsheets",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalSheets",
        "width": 1200,
        "height": 760,
        "minWidth": 760,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["binaries/llama/*"],
    "fileAssociations": [
      {
        "ext": ["csv", "xlsx"],
        "name": "Planilha",
        "description": "Planilha do LocalSheets",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
