{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalSheets",
  "version": "0.6.2",
  "identifier": "com.localsheets.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1434",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalSheets",
        "width": 1200,
        "height": 760,
        "minWidth": 760,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost http://127.0.0.1:*",
      "devCsp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src * ws: wss: ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["binaries/llama/*"],
    "fileAssociations": [
      {
        "ext": ["csv", "xlsx"],
        "name": "Planilha",
        "description": "Planilha do LocalSheets",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
